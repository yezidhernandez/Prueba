@using PiedraAzul.Client.Services.AuthServices
@using PiedraAzul.Client.States

@inject AuthenticationService AuthService
@inject UserState UserState
@inherits LayoutComponentBase

<div class="flex min-h-screen flex-col bg-gray-50">

    <!-- TOP BAR -->
    <div class="bg-primary text-sm text-white">
        <div class="mx-auto flex max-w-7xl justify-between px-6 py-2">
            <span>Llámanos: (301) 123-4567</span>
            <span>WhatsApp: Escríbenos ahora</span>
        </div>
    </div>

    <!-- HEADER -->
    <header class="border-b bg-white">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">

            <a href="/" class="flex items-center gap-2 text-lg font-semibold text-teal-700">
                <span class="text-xl"></span>
                Piedra Azul
            </a>

            <nav class="flex items-center gap-6 text-gray-600">
                <a href="/" class="transition-colors hover:text-gray-900">Inicio</a>
                @if (UserState?.User?.Roles.Contains("Admin") == true)
                {
                    <a href="/admin" class="transition-colors hover:text-gray-900">Admin</a>
                }
                <a class="hover:text-gray-900">Ayuda</a>

                @if (!_isLoaded)
                {
                    <a href="/account/auth" class="bg-primary rounded-md px-4 py-2 text-white hover:bg-teal-800">
                        Iniciar Sesión
                    </a>
                }
                else if (_isAuthenticated)
                {
                    <a href="/account" class="bg-primary rounded-md px-4 py-2 text-white hover:bg-teal-800">
                        Bienvenido de nuevo, @_userName
                    </a>
                }
                else
                {
                    <a href="/account/auth" class="bg-primary rounded-md px-4 py-2 text-white hover:bg-teal-800">
                        Iniciar Sesión
                    </a>
                }
            </nav>

        </div>
    </header>

    <main class="flex flex-1 flex-col">
        @Body
    </main>

    <!-- FOOTER -->
    <footer class="bg-strong text-gray-300">
        <div class="mx-auto grid max-w-7xl gap-10 px-6 py-12 md:grid-cols-3">

            <div>
                <h3 class="mb-4 flex items-center gap-2 text-lg font-semibold text-white">
                    Piedra Azul
                </h3>

                <p class="text-sm text-gray-400">
                    Dedicados a mejorar la calidad de vida de nuestra comunidad
                    con atención profesional y humana.
                </p>
            </div>

            <div>
                <h4 class="mb-4 font-semibold text-white">Enlaces</h4>

                <ul class="space-y-2 text-sm">
                    <li><a class="hover:text-white">Acerca de nosotros</a></li>
                    <li><a class="hover:text-white">Servicios médicos</a></li>
                    <li><a class="hover:text-white">Preguntas frecuentes</a></li>
                    <li><a class="hover:text-white">Política de privacidad</a></li>
                </ul>
            </div>

            <div>
                <h4 class="mb-4 font-semibold text-white">Contacto Directo</h4>

                <div class="space-y-3">

                    <button class="w-full rounded-md bg-teal-600 py-2 text-white hover:bg-teal-700">
                        (+57) 301-1234567
                    </button>

                    <button class="w-full rounded-md bg-green-600 py-2 text-white hover:bg-green-700">
                        WhatsApp
                    </button>

                </div>
            </div>

        </div>

        <div class="border-t border-slate-700 py-4 text-center text-sm text-gray-500">
            © 2026 Clínica Piedra Azul. Todos los derechos reservados.
        </div>

    </footer>

</div>

<!-- ERROR UI -->
<div id="blazor-error-ui"
     data-nosnippet
     class="-translate-x-1/2 fixed bottom-0 left-1/2 w-[90%] max-w-lg rounded-xl border border-red-200 bg-white p-6 shadow-xl">

    <div class="flex items-start gap-4">
        <div class="flex-1">

            <h2 class="mb-1 text-lg font-semibold text-gray-800">
                Algo no salió como esperábamos
            </h2>

            <p class="mb-4 text-sm text-gray-600">
                No se preocupe, esto a veces ocurre.
                Puede intentar recargar la página para continuar.
            </p>

            <div class="flex gap-3">
                <a href="."
                       class="reload rounded-lg bg-[#3A7D8C] px-4 py-2 text-sm font-medium text-white shadow hover:bg-[#2f6773]">
                    Recargar página
                </a>
            </div>

        </div>
    </div>
</div>

@code {
    private bool _isLoaded = false;
    private bool _isAuthenticated = false;
    private string? _userName;

    protected override async Task OnInitializedAsync()
    {
        if (UserState.User != null)
        {
            _isAuthenticated = true;
            _userName = UserState.User.Name;
            _isLoaded = true;
            return;
        }

        try
        {
            var result = await AuthService.GetCurrentUserAsync();

            if (result.IsSuccess && result.Value != null)
            {
                UserState.User = result.Value;

                _isAuthenticated = true;
                _userName = result.Value.Name;
            }
        }
        catch
        {
            _isAuthenticated = false;
        }

        _isLoaded = true;
    }
}