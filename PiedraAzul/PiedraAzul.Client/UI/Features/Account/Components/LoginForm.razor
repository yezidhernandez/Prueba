@using PiedraAzul.Client.Models
@using PiedraAzul.Client.Models.UserProfiles
@using PiedraAzul.Client.Services.AuthServices
@using PiedraAzul.Client.States
@inject NavigationManager NavigationManager
@inject AuthenticationService AuthService
@inject PasskeyService PasskeyService
@inject UserState UserState

<EditForm Model="@loginModel" OnValidSubmit="HandleLogin" class="mx-auto w-full max-w-lg">
    <DataAnnotationsValidator />
    <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-xl md:p-8">

        <!-- Header -->
        <h2 class="text-center text-2xl font-bold text-gray-800 md:text-left md:text-3xl">
            Ingresa a tu cuenta
        </h2>

        <p class="mb-6 mt-2 text-center text-gray-500 md:text-left">
            Accede a tus servicios médicos de forma segura.
        </p>

        <!-- Validation -->
        <ValidationSummary class="mb-4 text-sm text-red-500" />

        <!-- Usuario -->
        <div class="mb-4">
            <label class="mb-2 block text-sm font-semibold text-gray-700">
                Identificación, teléfono o correo
            </label>

            <InputText Value="@loginModel.Login"
                       ValueChanged="@(v => loginModel.Login = v)"
                       ValueExpression="() => loginModel.Login"
                       @oninput="@(e => loginModel.Login = e.Value?.ToString())"
                       class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-700
            transition focus:border-teal-400 focus:outline-none focus:ring-2
            focus:ring-teal-400"
                       placeholder="Ej: 101234567 o correo@email.com" />
        </div>

        <!-- Contraseña -->
        <div class="mb-4">
            <label class="mb-2 block text-sm font-semibold text-gray-700">
                Contraseña
            </label>
            <InputText Value="@loginModel.Password"
                       ValueChanged="@(v => loginModel.Password = v)"
                       ValueExpression="() => loginModel.Password"
                       @oninput="@(e => loginModel.Password = e.Value?.ToString())"
                       type="password"
                       class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-700
            transition focus:border-teal-400 focus:outline-none focus:ring-2
            focus:ring-teal-400"
                       placeholder="Tu contraseña" />
        </div>

        <!-- Error Message -->
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <p class="text-sm text-red-500">@_errorMessage</p>
        }

        <!-- Acciones -->
        <div class="mt-6 space-y-3">

            <button type="submit"
                    class="w-full rounded-lg bg-[#257D8D] py-3 font-semibold text-white shadow-md
                transition duration-200 hover:bg-[#1E5F6F]">
                Iniciar sesión
            </button>

            @if (_passkeySupported)
            {
                <button type="button"
                        @onclick="HandlePasskeyLogin"
                        disabled="@_passkeyLoading"
                        class="w-full flex items-center justify-center gap-2 rounded-lg border border-gray-300
                    bg-white py-3 font-semibold text-gray-700 shadow-sm transition duration-200
                    hover:bg-gray-50 disabled:opacity-60">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 1a5 5 0 1 0 5 5 5 5 0 0 0-5-5zm0 8a3 3 0 1 1 3-3 3 3 0 0 1-3 3zm-1 2h2v2.18A7 7 0 0 1 19 20H5a7 7 0 0 1 6-6.82V11z"/>
                    </svg>
                    @(_passkeyLoading ? "Verificando..." : "Ingresar con passkey")
                </button>
            }

            <button type="button"
                    @onclick="async () => await OnRegisterClick.InvokeAsync()"
                    class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-3 rounded-lg
                transition duration-200">
                ¿No tienes cuenta? Regístrate
            </button>

        </div>

    </div>
</EditForm>

@code {
    private LoginModel loginModel = new();

    [Parameter]
    public EventCallback OnRegisterClick { get; set; }
    [Parameter]
    public string? ReturnUrl { get; set; } = string.Empty;

    private string? _errorMessage;
    private bool _passkeySupported;
    private bool _passkeyLoading;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _passkeySupported = await PasskeyService.IsSupportedAsync();
        StateHasChanged();
    }

    private async Task HandleLogin()
    {
        var result = await AuthService.LoginAsync(loginModel);

        if (!result.IsSuccess)
        {
            _errorMessage = result.Error!.Type == "Auth"
                ? "Credenciales inválidas. Por favor, verifica tu información."
                : "Ocurrió un error al intentar iniciar sesión. Por favor, intenta nuevamente.";
            return;
        }

        // Force a full page reload so the server re-renders with the new auth cookie
        // and PersistentAuthenticationStateProvider picks up the authenticated state.
        var destination = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
        NavigationManager.NavigateTo(destination, forceLoad: true);
    }

    private async Task HandlePasskeyLogin()
    {
        _passkeyLoading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var result = await PasskeyService.LoginAsync();

            if (!result.IsSuccess)
            {
                _errorMessage = "No se pudo verificar la passkey. Intenta de nuevo.";
                return;
            }

            var destination = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
            NavigationManager.NavigateTo(destination, forceLoad: true);
        }
        catch
        {
            _errorMessage = "Autenticación con passkey cancelada o fallida.";
        }
        finally
        {
            _passkeyLoading = false;
            StateHasChanged();
        }
    }
}
